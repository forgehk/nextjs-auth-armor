# Copy to .env.local and fill in your project's values.

# Public — exposed to the browser. Safe to commit if it's truly the public anon key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Server-only — DO NOT commit. Used in route handlers for privileged ops.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Where login redirects to after success
NEXT_PUBLIC_SITE_URL=http://localhost:3000
